generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String      @id @default(cuid())
  email      String      @unique
  password   String
  name       String?
  createdAt  DateTime    @default(now())
  restaurant Restaurant?
}

model Restaurant {
  id               String     @id @default(cuid())
  name             String
  slug             String     @unique
  logoUrl          String?
  coverUrl         String?
  description      String?
  googleReviewLink String?
  themeColor       String     @default("#D4A017")
  discountText     String     @default("Get 10% off your next visit")
  ownerId          String     @unique
  owner            User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  categories        Category[]
  tables            Table[]
  customers         Customer[]
  upsellSuggestions UpsellSuggestion[]
  createdAt         DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

model Category {
  id           String     @id @default(cuid())
  name         String
  emoji        String?
  order        Int        @default(0)
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  items        MenuItem[]

  @@index([restaurantId])
}

model MenuItem {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  imageUrl    String?
  badges      String[]
  ingredients String[]
  isAvailable Boolean  @default(true)
  order       Int      @default(0)
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  upsellIds   String[]

  @@index([categoryId])
}

model Table {
  id           String     @id @default(cuid())
  number       Int
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  customers    Customer[]

  @@unique([restaurantId, number])
  @@index([restaurantId])
}

model Customer {
  id            String     @id @default(cuid())
  name          String?
  phone         String?
  tableId       String?
  table         Table?     @relation(fields: [tableId], references: [id])
  restaurantId  String
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  visitedAt     DateTime   @default(now())
  smsSent       Boolean    @default(false)
  smsSentAt     DateTime?
  reviewClicked Boolean    @default(false)

  @@index([restaurantId])
  @@index([smsSent, visitedAt])
}

// "addon" = pair two existing items, "combo" = bundle 2+ items at a price
model UpsellSuggestion {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  type         String     // "addon" | "combo"
  title        String
  reasoning    String
  itemIds      String[]   // IDs of MenuItem involved
  comboPrice   Decimal?   @db.Decimal(10, 2)
  status       String     @default("pending") // "pending" | "approved" | "rejected"
  createdAt    DateTime   @default(now())
  reviewedAt   DateTime?

  @@index([restaurantId, status])
}
